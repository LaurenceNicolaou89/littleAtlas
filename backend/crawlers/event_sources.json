      "venue": "span.event-venue",
      "description": "p.event-description",
      "link": "a.event-link"
    },
    "date_format": "%d/%m/%Y",
    "enabled": false
  },
  {
    "name": "Cyprus Events Sample (JSON API)",
    "url": "https://example.com/api/events",
    "type": "json",
    "json_paths": {
      "event_list": "data.events",
      "title": "title",
      "date": "start_date",
      "venue": "venue.name",
      "description": "description",
      "link": "url"
    },
    "date_format": "%Y-%m-%dT%H:%M:%S",
    "enabled": false
  }
